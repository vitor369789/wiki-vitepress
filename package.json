    "dotenv": "^16.3.1",
    "cookie-parser": "^1.4.6",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "vitepress": "^1.0.0",
    "vue": "^3.4.0",
    "concurrently": "^8.2.2"
