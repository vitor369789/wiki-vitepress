{
  "name": "minha-wiki",
  "version": "1.0.0",
  "description": "Wiki de documentação moderna com VitePress",
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
